// GamePool — Prisma Schema (PostgreSQL)
// See docs/database-design.md v2.0 for ER diagram and index rationale

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED

  @@map("user_status")
}

enum ProfileVisibility {
  PUBLIC
  CONNECTIONS_ONLY

  @@map("profile_visibility")
}

enum OtpChannel {
  EMAIL
  PHONE

  @@map("otp_channel")
}

enum OtpPurpose {
  SIGNUP
  LOGIN
  VERIFY_EMAIL
  VERIFY_PHONE
  PASSWORD_RESET

  @@map("otp_purpose")
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PROFESSIONAL

  @@map("skill_level")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY

  @@map("day_of_week")
}

enum MatchJoinRequestStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED

  @@map("match_join_request_status")
}

enum MatchStatus {
  DRAFT
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("match_status")
}

enum MatchVisibility {
  PUBLIC
  CONNECTIONS_ONLY
  INVITE_ONLY

  @@map("match_visibility")
}

enum VenueSource {
  MANUAL
  MARKETPLACE
  PARTNER
  VERIFIED

  @@map("venue_source")
}

enum ParticipantRole {
  HOST
  PARTICIPANT

  @@map("participant_role")
}

enum ParticipantStatus {
  PENDING
  CONFIRMED
  WAITLIST
  DECLINED
  REMOVED
  LEFT

  @@map("participant_status")
}

enum SportsConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED

  @@map("sports_connection_status")
}

enum TeammateRequestStatus {
  OPEN
  CLOSED
  EXPIRED

  @@map("teammate_request_status")
}

enum OpponentRequestStatus {
  OPEN
  MATCHED
  CLOSED
  EXPIRED

  @@map("opponent_request_status")
}

enum RequestInterestStatus {
  PENDING
  APPROVED
  DECLINED

  @@map("request_interest_status")
}

enum MatchInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED

  @@map("match_invite_status")
}

enum ReportReason {
  HARASSMENT
  NO_SHOW
  FAKE_PROFILE
  SPAM
  INAPPROPRIATE_CONTENT
  OTHER

  @@map("report_reason")
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED

  @@map("report_status")
}

enum AdminRole {
  SUPER_ADMIN
  MODERATOR
  SUPPORT

  @@map("admin_role")
}

enum AdminStatus {
  ACTIVE
  DISABLED

  @@map("admin_status")
}

enum NotificationType {
  MATCH_JOIN_REQUEST
  MATCH_JOIN_APPROVED
  MATCH_JOIN_DECLINED
  MATCH_FULL
  MATCH_CANCELLED
  MATCH_REMINDER
  MATCH_UPDATED
  MATCH_STARTED
  MATCH_INVITE
  MATCH_INVITE_ACCEPTED
  MATCH_INVITE_DECLINED
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  CONNECTION_DECLINED
  TEAMMATE_REQUEST_INTEREST
  TEAMMATE_REQUEST_APPROVED
  TEAMMATE_REQUEST_DECLINED
  OPPONENT_REQUEST_INTEREST
  OPPONENT_REQUEST_APPROVED
  OPPONENT_REQUEST_DECLINED
  WAITLIST_PROMOTED
  REPORT_STATUS_UPDATED
  WELCOME
  SYSTEM

  @@map("notification_type")
}

enum NotificationEntityType {
  MATCH
  USER
  SPORTS_CONNECTION
  TEAMMATE_REQUEST
  OPPONENT_REQUEST
  MATCH_INVITE
  REPORT
  SYSTEM

  @@map("notification_entity_type")
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid     String?    @map("firebase_uid") @db.VarChar(128)
  email           String?    @db.VarChar(255)
  phone           String?    @db.VarChar(20)
  passwordHash    String?    @map("password_hash") @db.VarChar(255)
  status          UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz
  phoneVerifiedAt DateTime?  @map("phone_verified_at") @db.Timestamptz
  lastLoginAt     DateTime?  @map("last_login_at") @db.Timestamptz
  deletedAt       DateTime?  @map("deleted_at") @db.Timestamptz
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  profile                    UserProfile?
  refreshTokens              RefreshToken[]
  userSports                 UserSport[]
  hostedMatches              Match[]                    @relation("MatchHost")
  matchParticipations        MatchParticipant[]         @relation("ParticipantUser")
  approvalsGiven             MatchParticipant[]         @relation("ApprovedByUser")
  notifications              Notification[]
  connectionsSent            SportsConnection[]         @relation("ConnectionRequester")
  connectionsReceived        SportsConnection[]         @relation("ConnectionRecipient")
  teammateRequestsCreated    TeammateRequest[]          @relation("TeammateRequestCreator")
  teammateInterests          TeammateRequestInterest[]  @relation("TeammateInterestUser")
  opponentRequestsCreated    OpponentRequest[]          @relation("OpponentRequestCreator")
  opponentInterests          OpponentRequestInterest[]  @relation("OpponentInterestUser")
  matchInvitesSent           MatchInvite[]              @relation("MatchInviter")
  matchInvitesReceived       MatchInvite[]              @relation("MatchInvitee")
  blocksInitiated            UserBlock[]                @relation("BlockerUser")
  blocksReceived             UserBlock[]                @relation("BlockedUser")
  reportsFiled               Report[]                   @relation("ReportReporter")
  reportsAgainst             Report[]                   @relation("ReportedUser")
  availability               UserAvailability[]
  matchJoinRequests          MatchJoinRequest[]         @relation("MatchJoinRequester")
  matchJoinRequestsReviewed  MatchJoinRequest[]         @relation("MatchJoinReviewer")

  @@index([status], map: "idx_users_status")
  @@index([firebaseUid], map: "idx_users_firebase_uid")
  @@map("users")
}

model UserProfile {
  id                        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                    String            @unique @map("user_id") @db.Uuid
  displayName               String            @map("display_name") @db.VarChar(100)
  avatarUrl                 String?           @map("avatar_url") @db.VarChar(500)
  bio                       String?           @db.Text
  city                      String            @db.VarChar(100)
  area                      String?           @db.VarChar(100)
  latitude                  Decimal?          @db.Decimal(9, 6)
  longitude                 Decimal?          @db.Decimal(9, 6)
  profileVisibility         ProfileVisibility @default(PUBLIC) @map("profile_visibility")
  emailNotificationsEnabled Boolean           @default(true) @map("email_notifications_enabled")
  pushNotificationsEnabled  Boolean           @default(true) @map("push_notifications_enabled")
  timezone                  String            @default("UTC") @db.VarChar(50)
  deletedAt                 DateTime?         @map("deleted_at") @db.Timestamptz
  createdAt                 DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([city, area], map: "idx_user_profiles_location")
  @@map("user_profiles")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  userAgent String?   @map("user_agent") @db.VarChar(500)
  ipAddress String?   @map("ip_address") @db.Inet
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt], map: "idx_refresh_tokens_user_expires")
  @@map("refresh_tokens")
}

model OtpVerification {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier   String     @db.VarChar(255)
  channel      OtpChannel
  purpose      OtpPurpose
  codeHash     String     @map("code_hash") @db.VarChar(64)
  attemptCount Int        @default(0) @map("attempt_count") @db.SmallInt
  expiresAt    DateTime   @map("expires_at") @db.Timestamptz
  verifiedAt   DateTime?  @map("verified_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz

  @@index([identifier, purpose, createdAt(sort: Desc)], map: "idx_otp_identifier_purpose")
  @@map("otp_verifications")
}

model Sport {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  iconUrl   String?  @map("icon_url") @db.VarChar(500)
  color     String?  @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userSports       UserSport[]
  matches          Match[]
  teammateRequests TeammateRequest[]
  opponentRequests OpponentRequest[]

  @@map("sports")
}

model UserSport {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  sportId    String     @map("sport_id") @db.Uuid
  skillLevel SkillLevel @map("skill_level")
  isPrimary  Boolean    @default(false) @map("is_primary")
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamptz
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Restrict)

  @@index([userId], map: "idx_user_sports_user")
  @@index([sportId, skillLevel], map: "idx_user_sports_sport_skill")
  @@map("user_sports")
}

model AdminUser {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String      @unique @db.VarChar(255)
  passwordHash String      @map("password_hash") @db.VarChar(255)
  displayName  String      @map("display_name") @db.VarChar(100)
  role         AdminRole   @default(MODERATOR)
  status       AdminStatus @default(ACTIVE)
  lastLoginAt  DateTime?   @map("last_login_at") @db.Timestamptz
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  reportsReviewed Report[]          @relation("ReportReviewer")
  auditEvents     AdminAuditEvent[]

  @@map("admin_users")
}

model AdminAuditEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminUserId String   @map("admin_user_id") @db.Uuid
  action      String   @db.VarChar(100)
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    String   @map("entity_id") @db.Uuid
  metadata    Json     @default("{}") @db.JsonB
  ipAddress   String?  @map("ip_address") @db.Inet
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([adminUserId, createdAt(sort: Desc)], map: "idx_admin_audit_admin")
  @@map("admin_audit_events")
}

model Match {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hostUserId          String          @map("host_user_id") @db.Uuid
  sportId             String          @map("sport_id") @db.Uuid
  teamId              String?         @map("team_id") @db.Uuid
  tournamentId        String?         @map("tournament_id") @db.Uuid
  title               String          @db.VarChar(200)
  format              String          @db.VarChar(50)
  notes               String?         @db.Text
  status              MatchStatus     @default(DRAFT)
  visibility          MatchVisibility @default(PUBLIC)
  skillLevelExpected  SkillLevel      @map("skill_level_expected")
  startsAt            DateTime        @map("starts_at") @db.Timestamptz
  endsAt              DateTime?       @map("ends_at") @db.Timestamptz
  durationMinutes     Int?            @map("duration_minutes")
  venueName           String          @map("venue_name") @db.VarChar(200)
  venueAddress        String?         @map("venue_address") @db.VarChar(500)
  venueId             String?         @map("venue_id") @db.Uuid
  venueSource         VenueSource     @default(MANUAL) @map("venue_source")
  venueLatitude       Decimal?        @map("venue_latitude") @db.Decimal(9, 6)
  venueLongitude      Decimal?        @map("venue_longitude") @db.Decimal(9, 6)
  city                String          @db.VarChar(100)
  area                String?         @db.VarChar(100)
  maxParticipants     Int             @map("max_participants")
  confirmedCount      Int             @default(0) @map("confirmed_count")
  waitlistEnabled     Boolean         @default(false) @map("waitlist_enabled")
  leaveCutoffHours    Int             @default(2) @map("leave_cutoff_hours") @db.SmallInt
  hiddenFromDiscovery Boolean         @default(false) @map("hidden_from_discovery")
  deletedAt           DateTime?       @map("deleted_at") @db.Timestamptz
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  host              User              @relation("MatchHost", fields: [hostUserId], references: [id], onDelete: Restrict)
  sport             Sport             @relation(fields: [sportId], references: [id], onDelete: Restrict)
  participants      MatchParticipant[]
  invites           MatchInvite[]
  joinRequests      MatchJoinRequest[]
  teammateRequests  TeammateRequest[]
  opponentRequests  OpponentRequest[]
  reports           Report[]          @relation("ReportedMatch")

  @@index([sportId, status, startsAt], map: "idx_matches_discovery")
  @@index([hostUserId, startsAt(sort: Desc)], map: "idx_matches_host")
  @@index([city, area, startsAt], map: "idx_matches_location")
  @@map("matches")
}

model SportsConnection {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterUserId String                 @map("requester_user_id") @db.Uuid
  recipientUserId String                 @map("recipient_user_id") @db.Uuid
  status          SportsConnectionStatus @default(PENDING)
  acceptedAt      DateTime?              @map("accepted_at") @db.Timestamptz
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz

  requester User @relation("ConnectionRequester", fields: [requesterUserId], references: [id], onDelete: Restrict)
  recipient User @relation("ConnectionRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)

  @@index([recipientUserId, status], map: "idx_sports_connections_recipient")
  @@index([requesterUserId, status], map: "idx_sports_connections_requester")
  @@map("sports_connections")
}

model TeammateRequest {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorUserId   String                @map("creator_user_id") @db.Uuid
  matchId         String?               @map("match_id") @db.Uuid
  sportId         String                @map("sport_id") @db.Uuid
  teamId          String?               @map("team_id") @db.Uuid
  title           String                @db.VarChar(200)
  description     String?               @db.Text
  requiredPlayers Int                   @map("required_players")
  skillLevel      SkillLevel            @map("skill_level")
  city            String                @db.VarChar(100)
  area            String?               @db.VarChar(100)
  status          TeammateRequestStatus @default(OPEN)
  expiresAt       DateTime?             @map("expires_at") @db.Timestamptz
  deletedAt       DateTime?             @map("deleted_at") @db.Timestamptz
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  creator   User                      @relation("TeammateRequestCreator", fields: [creatorUserId], references: [id], onDelete: Restrict)
  match     Match?                    @relation(fields: [matchId], references: [id], onDelete: SetNull)
  sport     Sport                     @relation(fields: [sportId], references: [id], onDelete: Restrict)
  interests TeammateRequestInterest[]

  @@index([sportId, status, city], map: "idx_teammate_requests_discovery")
  @@map("teammate_requests")
}

model TeammateRequestInterest {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teammateRequestId String                @map("teammate_request_id") @db.Uuid
  userId            String                @map("user_id") @db.Uuid
  status            RequestInterestStatus @default(PENDING)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  teammateRequest TeammateRequest @relation(fields: [teammateRequestId], references: [id], onDelete: Cascade)
  user            User            @relation("TeammateInterestUser", fields: [userId], references: [id], onDelete: Restrict)

  @@unique([teammateRequestId, userId], map: "uq_teammate_request_interests")
  @@map("teammate_request_interests")
}

model OpponentRequest {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorUserId     String                @map("creator_user_id") @db.Uuid
  matchId           String?               @map("match_id") @db.Uuid
  sportId           String                @map("sport_id") @db.Uuid
  teamId            String?               @map("team_id") @db.Uuid
  title             String                @db.VarChar(200)
  format            String                @db.VarChar(50)
  skillLevel        SkillLevel            @map("skill_level")
  city              String                @db.VarChar(100)
  area              String?               @db.VarChar(100)
  scheduledStartsAt DateTime?             @map("scheduled_starts_at") @db.Timestamptz
  scheduledEndsAt   DateTime?             @map("scheduled_ends_at") @db.Timestamptz
  matchedRequestId  String?               @map("matched_request_id") @db.Uuid
  status            OpponentRequestStatus @default(OPEN)
  expiresAt         DateTime?             @map("expires_at") @db.Timestamptz
  deletedAt         DateTime?             @map("deleted_at") @db.Timestamptz
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  creator        User                      @relation("OpponentRequestCreator", fields: [creatorUserId], references: [id], onDelete: Restrict)
  match          Match?                    @relation(fields: [matchId], references: [id], onDelete: SetNull)
  sport          Sport                     @relation(fields: [sportId], references: [id], onDelete: Restrict)
  matchedRequest OpponentRequest?          @relation("OpponentRequestPair", fields: [matchedRequestId], references: [id], onDelete: SetNull)
  pairedWith     OpponentRequest[]         @relation("OpponentRequestPair")
  interests      OpponentRequestInterest[]

  @@index([sportId, status, city], map: "idx_opponent_requests_discovery")
  @@map("opponent_requests")
}

model OpponentRequestInterest {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opponentRequestId String                @map("opponent_request_id") @db.Uuid
  userId            String                @map("user_id") @db.Uuid
  status            RequestInterestStatus @default(PENDING)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  opponentRequest OpponentRequest @relation(fields: [opponentRequestId], references: [id], onDelete: Cascade)
  user            User            @relation("OpponentInterestUser", fields: [userId], references: [id], onDelete: Restrict)

  @@unique([opponentRequestId, userId], map: "uq_opponent_request_interests")
  @@map("opponent_request_interests")
}

model UserAvailability {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  dayOfWeek DayOfWeek @map("day_of_week")
  startTime DateTime  @map("start_time") @db.Time
  endTime   DateTime  @map("end_time") @db.Time
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek, startTime, endTime], map: "uq_user_availability_window")
  @@index([userId], map: "idx_user_availability_user")
  @@map("user_availability")
}

model MatchJoinRequest {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId         String                 @map("match_id") @db.Uuid
  userId          String                 @map("user_id") @db.Uuid
  status          MatchJoinRequestStatus @default(PENDING)
  message         String?                @db.Text
  reviewedByUserId String?               @map("reviewed_by_user_id") @db.Uuid
  reviewedAt      DateTime?              @map("reviewed_at") @db.Timestamptz
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz

  match      Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user       User  @relation("MatchJoinRequester", fields: [userId], references: [id], onDelete: Restrict)
  reviewedBy User? @relation("MatchJoinReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([matchId, status], map: "idx_match_join_requests_match_status")
  @@index([userId, status, createdAt(sort: Desc)], map: "idx_match_join_requests_user")
  @@map("match_join_requests")
}

model MatchParticipant {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId          String            @map("match_id") @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  teamId           String?           @map("team_id") @db.Uuid
  role             ParticipantRole   @default(PARTICIPANT)
  status           ParticipantStatus
  removalReason    String?           @map("removal_reason") @db.Text
  approvedByUserId String?           @map("approved_by_user_id") @db.Uuid
  joinedAt         DateTime?         @map("joined_at") @db.Timestamptz
  leftAt           DateTime?         @map("left_at") @db.Timestamptz
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  match      Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user       User  @relation("ParticipantUser", fields: [userId], references: [id], onDelete: Restrict)
  approvedBy User? @relation("ApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([matchId, status], map: "idx_match_participants_match_status")
  @@index([userId, status, createdAt(sort: Desc)], map: "idx_match_participants_user")
  @@map("match_participants")
}

model MatchInvite {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId       String            @map("match_id") @db.Uuid
  inviterUserId String            @map("inviter_user_id") @db.Uuid
  inviteeUserId String            @map("invitee_user_id") @db.Uuid
  status        MatchInviteStatus @default(PENDING)
  message       String?           @db.Text
  expiresAt     DateTime?         @map("expires_at") @db.Timestamptz
  respondedAt   DateTime?         @map("responded_at") @db.Timestamptz
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  inviter User  @relation("MatchInviter", fields: [inviterUserId], references: [id], onDelete: Restrict)
  invitee User  @relation("MatchInvitee", fields: [inviteeUserId], references: [id], onDelete: Restrict)

  @@index([inviteeUserId, status], map: "idx_match_invites_invitee")
  @@map("match_invites")
}

model UserBlock {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blockerUserId String   @map("blocker_user_id") @db.Uuid
  blockedUserId String   @map("blocked_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  blocker User @relation("BlockerUser", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId], map: "uq_user_blocks_pair")
  @@index([blockedUserId], map: "idx_user_blocks_blocked")
  @@map("user_blocks")
}

model Report {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterUserId     String       @map("reporter_user_id") @db.Uuid
  reportedUserId     String?      @map("reported_user_id") @db.Uuid
  reportedMatchId    String?      @map("reported_match_id") @db.Uuid
  reason             ReportReason
  description        String?      @db.Text
  status             ReportStatus @default(OPEN)
  reviewedByAdminId  String?      @map("reviewed_by_admin_id") @db.Uuid
  reviewedAt         DateTime?    @map("reviewed_at") @db.Timestamptz
  resolutionNotes    String?      @map("resolution_notes") @db.Text
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  reporter      User       @relation("ReportReporter", fields: [reporterUserId], references: [id], onDelete: Restrict)
  reportedUser  User?      @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  reportedMatch Match?     @relation("ReportedMatch", fields: [reportedMatchId], references: [id], onDelete: SetNull)
  reviewedBy    AdminUser? @relation("ReportReviewer", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)

  @@index([status, createdAt], map: "idx_reports_queue")
  @@map("reports")
}

model Notification {
  id         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String                  @map("user_id") @db.Uuid
  type       NotificationType
  title      String                  @db.VarChar(200)
  body       String                  @db.Text
  payload    Json                    @default("{}") @db.JsonB
  entityType NotificationEntityType? @map("entity_type")
  entityId   String?                 @map("entity_id") @db.Uuid
  readAt     DateTime?               @map("read_at") @db.Timestamptz
  deletedAt  DateTime?               @map("deleted_at") @db.Timestamptz
  createdAt  DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_notifications_inbox")
  @@map("notifications")
}
