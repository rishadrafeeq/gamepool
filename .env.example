# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Pooled connection for app runtime (Neon pooler / PgBouncer)
DATABASE_URL="postgresql://gamepool:gamepool@localhost:5432/gamepool?schema=public"

# Direct connection for Prisma migrations
DIRECT_URL="postgresql://gamepool:gamepool@localhost:5432/gamepool?schema=public"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Firebase Client (public) ────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# ─── Firebase Admin (server only) ────────────────────────────────────────────
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ─── Admin Platform ──────────────────────────────────────────────────────────
ADMIN_JWT_SECRET="change-me-in-production-min-32-chars"
# Production: use scripts/bootstrap-admin.ts with ADMIN_BOOTSTRAP_SECRET (min 32 chars)
ADMIN_BOOTSTRAP_SECRET=""
# Never set true in production unless intentionally re-seeding with a strong password
ADMIN_ALLOW_SEED="false"

# ─── Optional: seed dev admin (development only) ─────────────────────────────
SEED_ADMIN_EMAIL="admin@gamepool.local"
SEED_ADMIN_PASSWORD="changeme"

# ─── Sentry (error monitoring) ───────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ─── Upstash Redis (distributed rate limiting) ───────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── E2E (Playwright — local / staging only) ─────────────────────────────────
E2E_BASE_URL="http://localhost:3000"
E2E_HOST_EMAIL=""
E2E_HOST_PASSWORD=""
E2E_JOINER_EMAIL=""
E2E_JOINER_PASSWORD=""
E2E_ADMIN_EMAIL=""
E2E_ADMIN_PASSWORD=""
# Firebase Console test phone number (e.g. +16505553434) and fixed OTP
E2E_TEST_PHONE=""
E2E_TEST_OTP="123456"
